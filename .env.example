# Copy this file to .env and adjust as needed.
# The app runs fine with zero config (SQLite, no Redis) for local dev.

# Defaults to a local SQLite file. For production use Postgres, e.g.:
# DATABASE_URL=postgresql://user:password@localhost:5432/shortener
DATABASE_URL=sqlite:///./urlshortener.db

# Optional. If unreachable, the app falls back to hitting the DB directly.
REDIS_URL=redis://localhost:6379/0

# CHANGE THIS in any real deployment.
SECRET_KEY=change-this-in-production-to-a-random-secret

BASE_URL=http://localhost:8000
